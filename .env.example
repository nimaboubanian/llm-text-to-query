# ===========================================
# LLM Text-to-Query Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is ignored by git for security.
#
# Only configure the databases you need!
# Start specific databases with profiles:
#   docker compose --profile postgres up -d
#   docker compose --profile mysql --profile mongodb up -d
#   docker compose --profile all up -d  (starts everything)
# ===========================================

# -----------------------------------------
# Ollama (LLM Service) - Required
# -----------------------------------------
OLLAMA_HOST=http://ollama:11434

# -----------------------------------------
# PostgreSQL Server (optional)
# Start with: docker compose --profile postgres up -d
# -----------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=company_data

# -----------------------------------------
# MySQL Server (optional)
# Start with: docker compose --profile mysql up -d
# -----------------------------------------
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=ecommerce_db
MYSQL_USER=user
MYSQL_PASSWORD=password

# -----------------------------------------
# MariaDB Server (optional)
# Start with: docker compose --profile mariadb up -d
# -----------------------------------------
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_DATABASE=library_db
MARIADB_USER=user
MARIADB_PASSWORD=password

# -----------------------------------------
# MongoDB Server (optional)
# Start with: docker compose --profile mongodb up -d
# -----------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# -----------------------------------------
# SQL Server (optional)
# Start with: docker compose --profile sqlserver up -d
# Note: Requires 2GB+ RAM, password must be complex
# -----------------------------------------
MSSQL_SA_PASSWORD=YourStrong@Passw0rd

# -----------------------------------------
# ClickHouse Server (optional)
# Start with: docker compose --profile clickhouse up -d
# -----------------------------------------
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=password
CLICKHOUSE_DB=analytics

# -----------------------------------------
# Neo4j Graph Database (optional)
# Start with: docker compose --profile neo4j up -d
# -----------------------------------------
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123